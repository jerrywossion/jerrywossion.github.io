---
const { name, iconSrc, url, class: className } = Astro.props
---

<a
    class:list={[
        className,
        'w-9 h-9 p-2 mr-1 hover:bg-white/[.3] dark:hover:bg-black/[.2] hover:border-white/[.1] rounded-full',
    ]}
    href={url}
    target="_blank"
>
    <img src={iconSrc} alt={name} />
</a>
